{
  "name": "acg_app",
  "private": true,
  "version": "0.2.0",
  "description": "A local-first Progressive Web App for cataloging ACG merchandise.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fuyo1622/acg_app.git"
  },
  "bugs": {
    "url": "https://github.com/fuyo1622/acg_app/issues"
  },
  "homepage": "https://acg-app-steel.vercel.app/",
  "type": "module",
  "engines": {
    "node": ">=20.19 <25"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npm run build && playwright test",
    "test:e2e:ui": "playwright test --ui",
    "check": "npm run version:check && npm run lint && npm test && npm run build",
    "audit": "npm audit --audit-level=high",
    "notices": "node scripts/generate-third-party-notices.mjs",
    "version:check": "node scripts/verify-version.mjs",
    "verify:release": "node scripts/verify-release-assets.mjs"
  },
  "dependencies": {
    "dexie": "^4.0.10",
    "dexie-react-hooks": "^1.1.7",
    "lucide-react": "^0.477.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.2.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^6.0.4",
    "eslint": "^10.7.0",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "vite": "^8.1.5",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.10"
  }
}
